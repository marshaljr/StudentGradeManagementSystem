<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.sms.controller.LoginController"
           styleClass="login-root">

    <!-- Background split - Desktop & Tablet responsive layout -->
    <HBox fx:id="loginContainer">
        <!-- Left Panel - Branding with visual elements -->
        <VBox styleClass="login-left" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="20">
            <!-- Decorative icon/badge -->
            <Label styleClass="login-icon" text="📚"/>
            
            <Label styleClass="brand-title" text="SMS"/>
            <Label styleClass="brand-subtitle" text="Student Grade&#10;Management System"/>
            
            <!-- Features list -->
            <VBox spacing="10" alignment="CENTER" style="-fx-padding: 30 0 0 0;">
                <HBox spacing="12" alignment="CENTER">
                    <Label text="✓" styleClass="feature-icon"/>
                    <Label text="Track performance easily" styleClass="feature-text"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER">
                    <Label text="✓" styleClass="feature-icon"/>
                    <Label text="Real-time grade updates" styleClass="feature-text"/>
                </HBox>
                <HBox spacing="12" alignment="CENTER">
                    <Label text="✓" styleClass="feature-icon"/>
                    <Label text="Secure access anytime" styleClass="feature-text"/>
                </HBox>
            </VBox>
            
            <Label styleClass="brand-desc"
                   text="Empowering teachers and students&#10;with smart academic tools."
                   wrapText="true" textAlignment="CENTER"
                   style="-fx-padding: 30 32 0 32;"/>
        </VBox>

        <!-- Right Panel - Login Form -->
        <VBox styleClass="login-right" HBox.hgrow="ALWAYS" alignment="CENTER" spacing="0">
            <VBox styleClass="login-card" alignment="TOP_LEFT" maxWidth="420">
                <padding><Insets top="45" right="45" bottom="45" left="45"/></padding>
                <spacing>0</spacing>

                <!-- Welcome section with accent bar -->
                <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 0 0 24 0;">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label styleClass="login-heading" text="Welcome Back"/>
                        <Label styleClass="login-subheading" text="Access your academic profile"/>
                    </VBox>
                    <Label text="🔐" style="-fx-font-size: 24px;"/>
                </HBox>

                <!-- Username -->
                <Label styleClass="field-label" text="Username" style="-fx-padding: 8 0 6 0;"/>
                <TextField fx:id="usernameField" styleClass="login-field login-input"
                           promptText="Enter your username or email">
                    <tooltip><Tooltip text="Enter your username or email address for login"/></tooltip>
                </TextField>
                <Region prefHeight="18"/>

                <!-- Password -->
                <Label styleClass="field-label" text="Password" style="-fx-padding: 8 0 6 0;"/>
                <HBox spacing="0" alignment="CENTER_LEFT" style="-fx-padding: 0;">
                    <PasswordField fx:id="passwordField" styleClass="login-field login-input"
                                   promptText="Enter your password" HBox.hgrow="ALWAYS">
                        <tooltip><Tooltip text="Enter your secure password (case-sensitive)"/></tooltip>
                    </PasswordField>
                    <Button fx:id="passwordToggleBtn" styleClass="password-toggle-btn"
                            text="👁" onAction="#togglePasswordVisibility"
                            focusTraversable="false">
                        <tooltip><Tooltip text="Toggle password visibility (Alt+P)"/></tooltip>
                    </Button>
                </HBox>
                <Region prefHeight="12"/>

                <!-- Error message (reserved space) -->
                <Label fx:id="errorLabel" styleClass="error-label"
                       text="" wrapText="true" minHeight="20"/>
                <Region prefHeight="16"/>

                <!-- Remember & Forgot Password row -->
                <HBox alignment="CENTER_LEFT" spacing="0" style="-fx-padding: 0 0 20 0;">
                    <CheckBox fx:id="rememberMeCheckBox" text="Remember me" 
                              styleClass="remember-checkbox" HBox.hgrow="ALWAYS">
                        <tooltip><Tooltip text="Keep me logged in on this device"/>
                        </tooltip>
                    </CheckBox>
                    <Hyperlink text="Forgot password?" onAction="#handleForgotPassword" 
                               styleClass="forgot-password-link">
                        <tooltip><Tooltip text="Reset your password via email verification"/></tooltip>
                    </Hyperlink>
                </HBox>

                <!-- Login button with accent -->
                <Button fx:id="loginButton" styleClass="btn-primary btn-login"
                        text="Sign In" maxWidth="Infinity"
                        onAction="#handleLogin">
                    <tooltip><Tooltip text="Click to authenticate your credentials (Enter)"/></tooltip>
                </Button>

                <Region prefHeight="36"/>

                <!-- Divider -->
                <HBox alignment="CENTER" spacing="12" style="-fx-padding: 0 0 20 0;">
                    <Region HBox.hgrow="ALWAYS" style="-fx-background-color: #E2E8F0; -fx-min-height: 1;"/>
                    <Label text="Or" styleClass="divider-text"/>
                    <Region HBox.hgrow="ALWAYS" style="-fx-background-color: #E2E8F0; -fx-min-height: 1;"/>
                </HBox>

                <!-- Demo info section -->
                <VBox spacing="10" styleClass="demo-info-box">
                    <Label styleClass="demo-label" text="Demo Credentials" style="-fx-text-alignment: center; -fx-padding: 0 0 8 0;"/>
                    
                    <GridPane hgap="12" vgap="8" style="-fx-padding: 0 8 0 8;">
                        <Label text="Admin:" styleClass="demo-key" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label text="admin / password123" styleClass="demo-value" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        
                        <Label text="Teacher:" styleClass="demo-key" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label text="t.smith / password123" styleClass="demo-value" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        
                        <Label text="Student:" styleClass="demo-key" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <Label text="s.alice / password123" styleClass="demo-value" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    </GridPane>
                </VBox>
            </VBox>
        </VBox>
    </HBox>
</StackPane>
