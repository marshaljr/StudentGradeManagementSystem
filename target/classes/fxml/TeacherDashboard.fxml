<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sms.controller.TeacherDashboardController"
            fx:id="mainRoot"
            styleClass="main-root">

    <!-- Top Navbar -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="0">
            <!-- Sidebar Toggle Button (visible on mobile/tablet) -->
            <Button fx:id="sidebarToggleBtn" styleClass="sidebar-toggle-btn"
                    text="☰" onAction="#toggleSidebar"
                    visible="false">
                <tooltip><Tooltip text="Toggle navigation menu (Ctrl+M)"/></tooltip>
            </Button>
            
            <Label styleClass="nav-brand" text="SMS Teacher"/>
            <Region HBox.hgrow="ALWAYS"/>
            
            <!-- Dark Mode Toggle -->
            <Button fx:id="btnThemeToggle" styleClass="theme-toggle-btn" text="🌙"
                    onAction="#toggleDarkMode">
                <tooltip><Tooltip text="Toggle dark mode (Ctrl+D)"/></tooltip>
            </Button>
            
            <Label fx:id="userLabel" styleClass="nav-user" text=""/>
            <Button styleClass="btn-logout" text="Logout" onAction="#handleLogout">
                <tooltip><Tooltip text="Sign out of your account"/></tooltip>
            </Button>
        </HBox>
    </top>

    <!-- Left Sidebar (collapsible) -->
    <left>
        <VBox fx:id="sidebarPane" styleClass="sidebar" spacing="4" prefWidth="200">
            <padding><Insets top="20" right="8" bottom="20" left="8"/></padding>
            <Label styleClass="sidebar-section" text="TEACHER MENU"/>
            
            <Button fx:id="btnDashboard" styleClass="sidebar-btn" 
                    text="≡  Dashboard"    onAction="#showDashboard"   maxWidth="Infinity">
                <tooltip><Tooltip text="View your dashboard (Ctrl+H)"/></tooltip>
            </Button>
            <Button fx:id="btnCourses" styleClass="sidebar-btn" 
                    text="📚  My Courses"   onAction="#showCourses"     maxWidth="Infinity">
                <tooltip><Tooltip text="View assigned courses (Ctrl+C)"/></tooltip>
            </Button>
            <Button fx:id="btnAssessments" styleClass="sidebar-btn" 
                    text="📝  Assessments"  onAction="#showAssessments" maxWidth="Infinity">
                <tooltip><Tooltip text="Manage assessments (Ctrl+E)"/></tooltip>
            </Button>
            <Button fx:id="btnGradeEntry" styleClass="sidebar-btn" 
                    text="✏️  Grade Entry"  onAction="#showGradeEntry"  maxWidth="Infinity">
                <tooltip><Tooltip text="Enter student grades (Ctrl+G)"/></tooltip>
            </Button>
            <Button fx:id="btnAttendance" styleClass="sidebar-btn" 
                    text="📅  Attendance"   onAction="#showAttendance"  maxWidth="Infinity">
                <tooltip><Tooltip text="Record attendance (Ctrl+A)"/></tooltip>
            </Button>
            <Button fx:id="btnReports" styleClass="sidebar-btn" 
                    text="📊  Class Reports" onAction="#showReports"    maxWidth="Infinity">
                <tooltip><Tooltip text="View class reports (Ctrl+R)"/></tooltip>
            </Button>
        </VBox>
    </left>

    <!-- Main Content Area -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <VBox fx:id="contentArea" spacing="20" styleClass="content-area">
                <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
                
                <!-- Breadcrumb Navigation -->
                <HBox fx:id="breadcrumb" spacing="8" alignment="CENTER_LEFT" styleClass="breadcrumb-bar">
                    <Label text="Home" styleClass="breadcrumb-item"/>
                    <Label text="›" styleClass="breadcrumb-separator"/>
                    <Label fx:id="breadcrumbCurrent" text="Dashboard" styleClass="breadcrumb-current"/>
                </HBox>
                
                <!-- Page Title -->
                <Label fx:id="pageTitle" styleClass="page-title" text="My Dashboard"/>
                
                <!-- Dynamic Content -->
                <VBox fx:id="subContent" spacing="12"/>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
