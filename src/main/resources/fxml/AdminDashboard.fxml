<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sms.controller.AdminDashboardController"
            fx:id="mainRoot"
            styleClass="main-root">

    <!-- ══ TOP NAV BAR ═══════════════════════════════════════════ -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="0">
            <!-- Sidebar Toggle Button (visible on mobile/tablet) -->
            <Button fx:id="sidebarToggleBtn" styleClass="sidebar-toggle-btn"
                    text="☰" onAction="#toggleSidebar"
                    visible="false">
                <tooltip><Tooltip text="Toggle navigation menu (Ctrl+M)"/></tooltip>
            </Button>
            
            <Label styleClass="nav-brand" text="SMS Admin"/>
            <Region HBox.hgrow="ALWAYS"/>
            
            <!-- Dark Mode Toggle -->
            <Button fx:id="btnThemeToggle" styleClass="theme-toggle-btn" text="🌙"
                    onAction="#toggleDarkMode">
                <tooltip><Tooltip text="Toggle dark mode (Ctrl+D)"/></tooltip>
            </Button>
            
            <Label fx:id="userLabel" styleClass="nav-user" text=""/>
            <Button styleClass="btn-logout" text="Logout" onAction="#handleLogout">
                <tooltip><Tooltip text="Sign out of your account"/></tooltip>
            </Button>
        </HBox>
    </top>

    <!-- ══ SIDEBAR (collapsible) ═════════════════════════════════ -->
    <left>
        <VBox fx:id="sidebarPane" styleClass="sidebar" spacing="4" prefWidth="200">
            <padding><Insets top="20" right="8" bottom="20" left="8"/></padding>
            <Label styleClass="sidebar-section" text="MANAGEMENT"/>
            
            <Button fx:id="btnDashboard" styleClass="sidebar-btn" 
                    text="≡  Dashboard"   onAction="#showDashboard" maxWidth="Infinity">
                <tooltip><Tooltip text="View admin dashboard (Ctrl+H)"/></tooltip>
            </Button>
            <Button fx:id="btnStudents" styleClass="sidebar-btn" 
                    text="👤  Students"    onAction="#showStudents"  maxWidth="Infinity">
                <tooltip><Tooltip text="Manage student accounts (Ctrl+S)"/></tooltip>
            </Button>
            <Button fx:id="btnTeachers" styleClass="sidebar-btn" 
                    text="👨‍🏫  Teachers"   onAction="#showTeachers"  maxWidth="Infinity">
                <tooltip><Tooltip text="Manage teacher accounts (Ctrl+T)"/></tooltip>
            </Button>
            <Button fx:id="btnCourses" styleClass="sidebar-btn" 
                    text="📚  Courses"     onAction="#showCourses"   maxWidth="Infinity">
                <tooltip><Tooltip text="Manage courses (Ctrl+C)"/></tooltip>
            </Button>
            
            <Region VBox.vgrow="ALWAYS"/>
            
            <Label styleClass="sidebar-section" text="REPORTS"/>
            <Button fx:id="btnReports" styleClass="sidebar-btn" 
                    text="📊  Reports"     onAction="#showReports"   maxWidth="Infinity">
                <tooltip><Tooltip text="View system reports (Ctrl+R)"/></tooltip>
            </Button>
        </VBox>
    </left>

    <!-- ══ CONTENT AREA ══════════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <VBox fx:id="contentArea" spacing="20" styleClass="content-area">
                <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

                <!-- Breadcrumb Navigation -->
                <HBox fx:id="breadcrumb" spacing="8" alignment="CENTER_LEFT" styleClass="breadcrumb-bar">
                    <Label text="Home" styleClass="breadcrumb-item"/>
                    <Label text="›" styleClass="breadcrumb-separator"/>
                    <Label fx:id="breadcrumbCurrent" text="Dashboard" styleClass="breadcrumb-current"/>
                </HBox>

                <!-- Page Title -->
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="pageTitle" styleClass="page-title" text="Dashboard"/>
                </HBox>

                <!-- Stat Cards Row (responsive grid) -->
                <HBox fx:id="statsRow" spacing="16" styleClass="stat-cards-row">
                    <VBox styleClass="stat-card stat-blue" HBox.hgrow="ALWAYS">
                        <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
                        <Label styleClass="stat-number" fx:id="statStudents" text="0"/>
                        <Label styleClass="stat-label"  text="Total Students"/>
                        <Label styleClass="stat-trend" fx:id="statStudentsTrend" text=""/>
                    </VBox>
                    <VBox styleClass="stat-card stat-green" HBox.hgrow="ALWAYS">
                        <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
                        <Label styleClass="stat-number" fx:id="statTeachers" text="0"/>
                        <Label styleClass="stat-label"  text="Total Teachers"/>
                        <Label styleClass="stat-trend" fx:id="statTeachersTrend" text=""/>
                    </VBox>
                    <VBox styleClass="stat-card stat-orange" HBox.hgrow="ALWAYS">
                        <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
                        <Label styleClass="stat-number" fx:id="statCourses"  text="0"/>
                        <Label styleClass="stat-label"  text="Active Courses"/>
                        <Label styleClass="stat-trend" fx:id="statCoursesTrend" text=""/>
                    </VBox>
                </HBox>

                <!-- Dynamic sub-content (students table, courses table, etc.) -->
                <VBox fx:id="subContent" spacing="12"/>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
